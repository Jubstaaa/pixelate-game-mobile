{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "http://localhost:3000/"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://pixelguessgame.com/"
            }
        },
        "production": {
            "env": {
                "EXPO_PUBLIC_API_URL": "https://pixelguessgame.com/"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
